{
  "name": "ai-mahjong",
  "version": "1.0.0",
  "description": "AI Mahjong Party - 3个AI Agent陪你打麻将",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "dev:client-new": "vite --config vite.client-new.config.ts",
    "dev:new": "concurrently \"npm run dev:server\" \"npm run dev:client-new\"",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "vite build",
    "build:client-new": "vite build --config vite.client-new.config.ts",
    "start": "node dist/server/index.js",
    "preview": "vite preview",
    "preview:new": "vite preview --config vite.client-new.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:sidecar && tauri build",
    "build:sidecar": "node scripts/build-sidecar.js"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "ai": "^6.0.116",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "framer-motion": "^10.16.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.3",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.20",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "pkg": "^5.8.1",
    "sharp": "^0.34.5",
    "tsx": "^4.1.4",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
