{
  // OpenClaw 配置示例 - 添加 n8n 桥接
  // OpenClaw 与 n8n 在同一台电脑 (192.168.3.19)
  // 将此内容合并到 ~/.openclaw/openclaw.json 中
  
  hooks: {
    enabled: true,
    token: "openclaw_secret_token_change_me",  // 修改为安全的 Token
    path: "/hooks",
    allowedAgentIds: ["main", "n8n-bridge"]
  },
  
  skills: {
    entries: {
      "n8n-bridge": {
        enabled: true,
        config: {
          // n8n 服务器地址 - 同一台电脑可用 localhost
          n8nUrl: "http://127.0.0.1:5678",
          // 认证 Token (与 n8n 中配置的一致)
          authToken: "openclaw_secret_token_change_me",
          // 轮询间隔 (毫秒)
          pollInterval: 5000
        }
      }
    }
  },
  
  // 可选: 配置定时轮询 n8n 消息
  automation: {
    cron: {
      "poll-n8n-messages": {
        enabled: true,
        schedule: "*/10 * * * * *",  // 每10秒
        action: "webhook",
        webhook: {
          url: "http://127.0.0.1:18789/hooks/agent",
          method: "POST",
          headers: {
            "Authorization": "Bearer ${OPENCLAW_HOOKS_TOKEN}"
          },
          body: {
            message: "检查 n8n 是否有新消息，如果有就处理",
            name: "n8n-poll",
            agentId: "main"
          }
        }
      }
    }
  }
}
