{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Mahjong Party",
  "version": "1.0.0",
  "identifier": "com.aimahjong.party",
  "build": {
    "beforeBuildCommand": "npm run build:client-new",
    "beforeDevCommand": "npm run dev:client-new",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5174"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AI Mahjong Party",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "hiddenTitle": true,
        "decorations": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/ai-mahjong-server"
    ],
    "resources": [
      "../locales/**/*"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/header.bmp",
        "sidebarImage": "icons/sidebar.bmp",
        "license": null,
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "single-instance": {
      "enabled": true
    }
  }
}
